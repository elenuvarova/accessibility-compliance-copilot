PORT=8001
NODE_ENV=development

# Leave blank locally — the app uses SQLite automatically.
# On Render, DATABASE_URL is injected from the Postgres service via render.yaml.
# DATABASE_URL=postgres://...

# Required for AI fix suggestions (POST /api/issues/:id/suggest-fix)
# Free key at console.groq.com — uses llama-3.3-70b-versatile
# GROQ_API_KEY=gsk_...

# ── Optional API protection ───────────────────────────────────────────────────
# If APP_API_KEY is set, all mutating and AI/cost endpoints (POST/PATCH /api/scans,
# /api/projects, /suggest-fix, /holistic-review, /compliance-report,
# /manual-checklist, issue/check PATCH) require it via either header:
#   Authorization: Bearer <key>   OR   X-API-Key: <key>
# If APP_API_KEY is UNSET (the default), those endpoints stay OPEN — this keeps
# local development and the public demo working with no auth. Set it in
# production to lock the API down.
# APP_API_KEY=

# For the frontend to send the key automatically, set VITE_API_KEY to the SAME
# value at build time (frontend/.env or your build env). Leave unset for the
# open demo.
# VITE_API_KEY=

# ── Optional cost / abuse guards (sensible defaults if unset) ─────────────────
# Max AI/Groq calls per process per minute (denial-of-wallet guard).
# LLM_RATE_PER_MINUTE=20
# Max background scans running at once.
# MAX_CONCURRENT_SCANS=3
